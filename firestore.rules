rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isStaff() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'facilitator'] ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admincommove@gmail.com'
        );
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admincommove@gmail.com'
        );
    }

    // ─── OTP Verification Codes ───────────────────────────────────────────────
    // Written by the client before authentication exists.
    // Security is enforced in app logic: 10-min expiry + 5-attempt limit.

    match /otpCodes/{emailKey} {
      allow read, write: if true;
    }

    // ─── Users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff() ||
        get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
      allow list: if true; // username uniqueness check runs before auth exists
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isStaff()) &&
        !(resource.data.email == 'admincommove@gmail.com' && (
          request.resource.data.email != 'admincommove@gmail.com' ||
          request.resource.data.role != 'admin'
        ));
      allow delete: if isAdmin() && resource.data.email != 'admincommove@gmail.com';
    }

    // ─── Events ───────────────────────────────────────────────────────────────

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isStaff() ||
        // Creator may edit their own pending event (non-sensitive fields only)
        (
          isAuthenticated() &&
          resource.data.createdBy == request.auth.uid &&
          resource.data.status == 'pending' &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'isAdmin', 'role', 'createdBy'])
        ) ||
        // Any authenticated user may update analytics counters only
        (
          isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['viewCount', 'saveCount', 'interestedCount', 'checkInCount', 'feedbackCount', 'averageRating'])
        );
      allow delete: if isStaff();
    }

    // ─── Registrations ────────────────────────────────────────────────────────

    match /registrations/{registrationId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    // ─── Notifications ────────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && (
        isStaff() ||
        request.resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data.email == 'admincommove@gmail.com'
      );
    }

    // ─── Event Feedback ───────────────────────────────────────────────────────

    match /eventFeedback/{feedbackId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isStaff();
    }
  }
}
