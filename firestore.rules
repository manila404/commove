rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isStaff() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'facilitator'] ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admincommove@gmail.com'
        );
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'admincommove@gmail.com'
        );
    }

    // ─── OTP Verification Codes ───────────────────────────────────────────────
    // Allow public read/write access because signup OTP requests occur before 
    // the user is authenticated (request.auth is null).
    match /otpCodes/{otpDocId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.keys().hasAll([
        'email',
        'code',
        'createdAt',
        'expiresAt',
        'attempts'
      ]);
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff() ||
        get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';

      allow list: if true;

      allow create: if isOwner(userId);

      allow update: if (isOwner(userId) || isStaff()) &&
        !(resource.data.email == 'admincommove@gmail.com' && (
          request.resource.data.email != 'admincommove@gmail.com' ||
          request.resource.data.role != 'admin'
        ));

      allow delete: if isAdmin() && resource.data.email != 'admincommove@gmail.com';
    }

    // ─── Events ───────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;

      allow create: if isAuthenticated();

      allow update: if isStaff() ||
        (
          isAuthenticated() &&
          resource.data.createdBy == request.auth.uid &&
          resource.data.status == 'pending' &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'isAdmin', 'role', 'createdBy'])
        ) ||
        (
          isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'viewCount',
              'saveCount',
              'likeCount',
              'interestedCount',
              'checkInCount',
              'feedbackCount',
              'averageRating'
            ])
        );

      allow delete: if isStaff();
    }

    // ─── Registrations ────────────────────────────────────────────────────────
    match /registrations/{registrationId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isStaff());

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isStaff();

      allow delete: if isStaff();
    }

    // ─── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notificationId} {

      // Users can only read their own notifications
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // Users can only update their own notification read status
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isRead']);

      // Users can only delete their own notifications
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // Staff can create notifications for other users.
      // Regular users can only create notifications for themselves.
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll([
          'userId',
          'title',
          'body',
          'type',
          'createdAt',
          'isRead'
        ])
        && (
          isStaff() ||
          request.resource.data.userId == request.auth.uid
        );
    }

    // ─── Event Feedback ───────────────────────────────────────────────────────
    match /eventFeedback/{feedbackId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isStaff();
    }

    // ─── App Config ───────────────────────────────────────────────────────────
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
